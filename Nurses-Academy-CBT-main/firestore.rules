rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isChangingProtectedFields() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasAny([
        'entranceExamPaid',
        'entranceExamPaidAt',
        'entranceExamRef',
        'subscribed',
        'subscriptionPlan',
        'subscriptionExpiry',
        'role',
      ]);
    }

    match /users/{userId} {
      // Any logged-in student can READ another student's public profile.
      // This is required for: leaderboard → public profile → chat flow.
      // Writes remain strictly owner-only (with protected field guards).

      allow read:   if isAuth();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && !isChangingProtectedFields()) || isAdmin();
      allow delete: if isAdmin();
      match /{subCollection}/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /questions/{questionId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /entranceExamQuestions/{questionId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /entranceExamSchools/{schoolId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /entranceExamSubjects/{subjId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /entranceExamConfig/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /dailyMockSchedule/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /entranceExamSessions/{sessionId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /entrancePausedExams/{docId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /examSessions/{sessionId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pausedExams/{docId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /payments/{paymentId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Global "new exam available" daily notifications (e.g. Daily Practice,
    // Entrance Exam Daily Mock). Documents use a deterministic date-based ID
    // and are created idempotently — once a doc exists for a given day it
    // is never modified again, only read.
    match /dailyAnnouncements/{annId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    match /bookmarks/{bookmarkId} {
      allow read, write: if isAuth() && (resource == null ? request.resource.data.userId == request.auth.uid : resource.data.userId == request.auth.uid || isAdmin());
    }

    match /announcements/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /accessCodes/{id} {
      allow read, write: if isAdmin();
    }

    match /scheduledExams/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /courses/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /topics/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /leaderboard/{id} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    match /config/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Direct student-to-student chat ─────────────────────────────────────
    // chatId is always [uid1, uid2].sort().join('_')
    // A student can only access a chat if their own UID is part of the chatId.
    match /directChats/{chatId} {
      allow read, write: if isAuth() &&
        chatId.matches('.*' + request.auth.uid + '.*');

      match /messages/{msgId} {
        allow read:   if isAuth() &&
          chatId.matches('.*' + request.auth.uid + '.*');
        allow create: if isAuth() &&
          chatId.matches('.*' + request.auth.uid + '.*') &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isAuth() &&
          chatId.matches('.*' + request.auth.uid + '.*');
        allow delete: if isAdmin();
      }

      // Typing indicators sub-collection
      match /typing/{typingUid} {
        allow read, write: if isAuth() &&
          chatId.matches('.*' + request.auth.uid + '.*');
      }
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
