rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSubAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'subadmin';
    }

    function isAdminOrSubAdmin() {
      return isAdmin() || isSubAdmin();
    }

    function isChangingProtectedFields() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasAny([
        'entranceExamPaid',
        'entranceExamPaidAt',
        'entranceExamRef',
        'subscribed',
        'subscriptionPlan',
        'subscriptionExpiry',
        'role',
      ]);
    }

    match /users/{userId} {
      allow read:   if isAuth();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) && !isChangingProtectedFields()) || isAdmin();
      allow delete: if isAdmin();
      match /{subCollection}/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /questions/{questionId} {
      allow read:  if isAuth();
      allow write: if isAdminOrSubAdmin();
    }

    match /exams/{examId} {
      allow read:  if isAuth();
      allow write: if isAdminOrSubAdmin();
    }

    match /entranceExamQuestions/{questionId} {
      allow read:  if isAuth();
      allow write: if isAdminOrSubAdmin();
    }

    match /entranceExamSchools/{schoolId} {
      allow read:  if isAuth();
      allow write: if isAdminOrSubAdmin();
    }

    match /entranceExamSubjects/{subjId} {
      allow read:  if isAuth();
      allow write: if isAdminOrSubAdmin();
    }

    match /entranceExamConfig/{docId} {
      allow read:  if isAuth();
      allow write: if isAdminOrSubAdmin();
    }

    match /dailyMockSchedule/{docId} {
      allow read:  if isAuth();
      allow write: if isAdminOrSubAdmin();
    }

    match /entranceExamSessions/{sessionId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /entrancePausedExams/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /examSessions/{sessionId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pausedExams/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /payments/{paymentId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /dailyAnnouncements/{annId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    match /bookmarks/{bookmarkId} {
      allow read, write: if isAuth() && (
        resource == null
          ? request.resource.data.userId == request.auth.uid
          : resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    match /questionNotes/{noteId} {
      allow read, write: if isAuth() && (
        resource == null
          ? request.resource.data.userId == request.auth.uid
          : resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    match /entranceBookmarks/{bookmarkId} {
      allow read, write: if isAuth() && (
        resource == null
          ? request.resource.data.userId == request.auth.uid
          : resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    match /announcements/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /accessCodes/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /scheduledExams/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /courses/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /topics/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /leaderboard/{id} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    match /config/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Direct student-to-student chat ────────────────────────────────────

    match /directChats/{chatId} {
      function isParticipant() {
        return isAuth() && resource.data.participants.hasAny([request.auth.uid]);
      }
      function isParticipantByCreate() {
        return isAuth() && request.resource.data.participants.hasAny([request.auth.uid]);
      }
      function chatParticipants() {
        return exists(/databases/$(database)/documents/directChats/$(chatId))
          ? get(/databases/$(database)/documents/directChats/$(chatId)).data.participants
          : [];
      }

      allow read:   if isAuth();
      allow create: if isParticipantByCreate();
      // Reverted: no participants-field guard — ChatPage always resends
      // participants in every setDoc merge, so blocking it breaks sends.
      allow update: if isParticipant();
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read:   if isAuth() && chatParticipants().hasAny([request.auth.uid]);
        allow create: if isAuth() &&
          chatParticipants().hasAny([request.auth.uid]) &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isAuth() && chatParticipants().hasAny([request.auth.uid]);
        allow delete: if isAdmin();
      }

      match /typing/{typingUid} {
        allow read, write: if isAuth() && chatParticipants().hasAny([request.auth.uid]);
      }
    }

    // ── NMCN CBT Group Chats ──────────────────────────────────────────────

    match /groupChats/{groupId} {
      allow read:  if isAuth();
      allow write: if isAuth();

      match /messages/{msgId} {
        allow read:   if isAuth();
        allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuth();
        allow delete: if isAdmin();
      }

      match /members/{memberId} {
        allow read:  if isAuth();
        allow write: if isAuth() && memberId == request.auth.uid;
      }

      match /typing/{typingUid} {
        allow read:  if isAuth();
        allow write: if isAuth() && typingUid == request.auth.uid;
      }
    }

    // ── Entrance Exam Group Chats ─────────────────────────────────────────

    match /entranceGroupChats/{groupId} {
      allow read:  if isAuth();
      allow write: if isAuth();

      match /messages/{msgId} {
        allow read:   if isAuth();
        allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuth();
        allow delete: if isAdmin();
      }

      match /members/{memberId} {
        allow read:  if isAuth();
        allow write: if isAuth() && memberId == request.auth.uid;
      }

      match /typing/{typingUid} {
        allow read:  if isAuth();
        allow write: if isAuth() && typingUid == request.auth.uid;
      }
    }

  }
}
