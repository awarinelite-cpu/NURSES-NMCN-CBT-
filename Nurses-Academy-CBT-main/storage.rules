rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Voice notes: voiceNotes/{chatId}/{filename}
    // Any authenticated user can upload/read voice notes in chats they participate in.
    match /voiceNotes/{chatId}/{filename} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.size < 20 * 1024 * 1024  // 20 MB max
                    && request.resource.contentType.matches('audio/.*');
      allow delete: if request.auth != null;
    }

    // Chat images: chatImages/{chatId}/{filename}
    match /chatImages/{chatId}/{filename} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.size < 10 * 1024 * 1024  // 10 MB max
                    && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Profile pictures
    match /profilePictures/{userId}/{filename} {
      allow read:   if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
